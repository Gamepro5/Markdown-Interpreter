{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Interpreter",
  "version": "1.0.0",
  "identifier": "com.gamepro5.markdown-interpreter",
  "build": {
    "frontendDist": "../renderer",
    "beforeBuildCommand": "npm run bundle",
    "beforeDevCommand": "npm run bundle"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Interpreter",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage"],
    "publisher": "Gamepro5",
    "homepage": "https://github.com/Gamepro5/Markdown-Interpreter",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "Utility",
    "shortDescription": "Lightweight markdown viewer and editor",
    "longDescription": "Markdown Interpreter is a lightweight desktop app for viewing and editing markdown files with live preview.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "mimeType": "text/markdown",
        "description": "Markdown File"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      }
    },
    "linux": {
      "deb": {
        "desktopTemplate": "../assets/markdown-interpreter.desktop"
      },
      "rpm": {
        "desktopTemplate": "../assets/markdown-interpreter.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
